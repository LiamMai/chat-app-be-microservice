APP_NAME=chat-app-microservice
NODE_ENV=development

# CORS
CORS_ENABLED=true
CORS_ORIGIN=*
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS

# Redis
REDIS_HOST=localhost
REDIS_HOST_PORT=63790
REDIS_CONTAINER_PORT=6379
REDIS_PASSWORD=MyStr0ngPassword
REDIS_URL=redis://default:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_HOST_PORT}
REDIS_DB=0

# Cache
CACHE_TTL_IN_SECONDS=60
CACHE_MAX_ITEMS=5000

# Rabitmq
RABBITMQ_HOST_PORT=56720
RABBITMQ_CONTAINER_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=MyStr0ngPassword
RABBITMQ_HOST=localhost
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_HOST_PORT}

# MongoDB
MONGODB_USERNAME=mongo_admin
MONGODB_PASSWORD=MyStr0ngPassword
MONGODB_PRIMARY_HOST=localhost
MONGODB_PRIMARY_HOST_PORT=37017
MONGODB_PRIMARY_CONTAINER_PORT=37017
MONGODB_BASE_URL=mongodb://${MONGODB_USERNAME}:${MONGODB_PASSWORD}@${MONGODB_PRIMARY_HOST}:${MONGODB_PRIMARY_HOST_PORT}

# Postgres
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=MyStr0ngPassword
POSTGRES_PRIMARY_HOST=localhost
POSTGRES_PRIMARY_HOST_PORT=5432
POSTGRES_PRIMARY_CONTAINER_PORT=5432
POSTGRES_BASE_URL=postgresql://${POSTGRES_USERNAME}:${POSTGRES_PASSWORD}@${POSTGRES_PRIMARY_HOST}:${POSTGRES_PRIMARY_HOST_PORT}

# JWT RS256 — 4096-bit key pair
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=chat-app